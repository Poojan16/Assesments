# .env.example — copy to .env and fill in real values before running any script
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost           # PostgreSQL server hostname
DB_PORT=5432                # PostgreSQL port
DB_NAME=pipeline_db         # Database name
DB_USER=pipeline_user       # Database user
DB_PASSWORD=changeme        # Database password

# ── FTP Watcher ───────────────────────────────────────────────────────────────
FTP_HOST=ftp.example.com    # FTP server hostname
FTP_PORT=21                 # FTP port
FTP_USER=ftp_user           # FTP username
FTP_PASSWORD=changeme       # FTP password
FTP_REMOTE_DIR=/incoming    # Remote directory to watch

# ── SFTP (Paramiko) ───────────────────────────────────────────────────────────
SFTP_HOST=sftp.example.com  # SFTP server hostname
SFTP_PORT=22                # SFTP port
SFTP_USER=sftp_user         # SFTP username
SFTP_KEY_PATH=~/.ssh/id_rsa # Absolute path to SSH private key
SFTP_REMOTE_DIR=/incoming   # Remote SFTP directory to watch

# ── Watcher behaviour ─────────────────────────────────────────────────────────
WATCHER_POLL_INTERVAL=30    # Seconds between directory polls
WATCHER_MODE=ftp            # Transport: ftp | sftp

# ── AI / LangChain ────────────────────────────────────────────────────────────
LANGCHAIN_LLM_PROVIDER=openai  # LLM backend: openai | anthropic
OPENAI_API_KEY=sk-...          # OpenAI API key (required for openai provider)

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production  # Django SECRET_KEY
DJANGO_DEBUG=true                          # true | false
DJANGO_ALLOWED_HOSTS=*                     # Comma-separated allowed hosts
DJANGO_SETTINGS_MODULE=dashboard.settings  # Django settings module path

# ── setup.sh ──────────────────────────────────────────────────────────────────
VENV_DIR=./venv                                        # Virtual-environment directory
SEED_ROWS=5000                                         # Rows to generate for seed data
SEED_OUTPUT=./data/sample_transactions.xlsx            # Seed file output path

# ── start.sh / stop.sh ────────────────────────────────────────────────────────
APP_PORT=8000               # Django listen port
LOG_DIR=./logs              # Directory for per-service log files (web.log, watcher.log)
PID_DIR=./run               # Directory for PID files (web.pid, watcher.pid)
STOP_TIMEOUT=10             # Seconds to wait for graceful shutdown before SIGKILL

# ── ops.sh ────────────────────────────────────────────────────────────────────
DATA_DIR=./data             # Source directory scanned for processed .xlsx files
ARCHIVE_DIR=./archives      # Destination for compressed tar.gz archives
ARCHIVE_RETAIN_DAYS=30      # Delete archives older than this many days
DATA_RETAIN_DAYS=7          # Archive (and remove) originals older than this many days
