# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pipeline_db
DB_USER=pipeline_user
DB_PASSWORD=changeme

# ── FTP Watcher ───────────────────────────────────────────────────────────────
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=ftp_user
FTP_PASSWORD=changeme
FTP_REMOTE_DIR=/incoming

# ── SFTP (Paramiko) ───────────────────────────────────────────────────────────
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USER=sftp_user
SFTP_KEY_PATH=~/.ssh/id_rsa      # absolute path to private key file
SFTP_REMOTE_DIR=/incoming

# ── Watcher behaviour ─────────────────────────────────────────────────────────
WATCHER_POLL_INTERVAL=30         # seconds between directory polls
WATCHER_MODE=ftp                 # ftp | sftp

# ── AI / LangChain ────────────────────────────────────────────────────────────
LANGCHAIN_LLM_PROVIDER=openai    # openai | other supported provider
OPENAI_API_KEY=sk-...            # your OpenAI API key
